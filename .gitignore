# Terraform local working directories
**/.terraform/*
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json
!*.tfvars.example
!*.auto.tfvars.example

# Terraform plan output
*.tfplan
*.plan
plan.out

# Terraform lock files
# Keep this file committed for provider version reproducibility.
!.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files for local-only Terraform changes
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Kubernetes access files
kubeconfig
kubeconfig.*
*.kubeconfig
*.kubeconfig.yaml
*.kubeconfig.yml
.kube/

# Local environment files
.env
.env.*
!.env.example

# Secrets and credentials
*.pem
*.key
*.crt
*.p12
*.pfx
credentials
credentials.*
secrets.yaml
secret.yaml
*-secret.yaml
*-secrets.yaml

# Sealed Secrets private keys must never be committed
sealed-secrets-key*
sealed-secrets*.key
sealed-secrets*.pem

# Velero credentials
velero-credentials
velero-credentials.*
credentials-velero
credentials-velero.*

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/